{
  "name": "bagomri-portfolio",
  "version": "1.0.0",
  "description": "بورتفوليو احترافي ثلاثي التخصص (Flutter, UI/UX, Graphics) مع تجربة مستخدم غامرة",
  "main": "index.html",
  "scripts": {
    "sass": "sass sass/main.scss css/main.css",
    "sass:watch": "sass --watch sass/main.scss:css/main.css",
